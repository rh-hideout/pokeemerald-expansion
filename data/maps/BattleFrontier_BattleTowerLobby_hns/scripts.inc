	goto BattleFrontier_BattleTowerLobby_EventScript_ReadRulesBoard_hns
	end

BattleFrontier_BattleTowerLobby_EventScript_RulesMultiLink_hns::
	msgbox BattleFrontier_BattleTowerLobby_Text_ExplainMultiLinkRules_hns, MSGBOX_DEFAULT
	goto BattleFrontier_BattleTowerLobby_EventScript_ReadRulesBoard_hns
	end

BattleFrontier_BattleTowerLobby_EventScript_ExitRules_hns::
	releaseall
	end

