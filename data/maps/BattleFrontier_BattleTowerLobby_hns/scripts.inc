	multichoice 17, 2, MULTI_BATTLE_TOWER_RULES, FALSE
	switch VAR_RESULT
	case 0, BattleFrontier_BattleTowerLobby_EventScript_RulesTower_hns
	case 1, BattleFrontier_BattleTowerLobby_EventScript_RulesMons_hns
	case 2, BattleFrontier_BattleTowerLobby_EventScript_RulesSalon_hns
	case 3, BattleFrontier_BattleTowerLobby_EventScript_RulesMultiLink_hns
	case 4, BattleFrontier_BattleTowerLobby_EventScript_ExitRules_hns
	case MULTI_B_PRESSED, BattleFrontier_BattleTowerLobby_EventScript_ExitRules_hns
	end

BattleFrontier_BattleTowerLobby_EventScript_RulesTower_hns::
	msgbox BattleFrontier_BattleTowerLobby_Text_ExplainTowerRules_hns, MSGBOX_DEFAULT
	goto BattleFrontier_BattleTowerLobby_EventScript_ReadRulesBoard_hns
	end

BattleFrontier_BattleTowerLobby_EventScript_RulesMons_hns::
	msgbox BattleFrontier_BattleTowerLobby_Text_ExplainMonRules_hns, MSGBOX_DEFAULT
