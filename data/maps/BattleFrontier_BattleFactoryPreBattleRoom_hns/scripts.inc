	msgbox BattleFrontier_BattleFactoryPreBattleRoom_Text_LikeToSwapMon_hns, MSGBOX_YESNO
	switch VAR_RESULT
	case NO, BattleFrontier_BattleFactoryPreBattleRoom_EventScript_EnterBattleRoom_hns
