	msgbox BattleFrontier_BattleFactoryPreBattleRoom_Text_YourSwapIsComplete_hns, MSGBOX_DEFAULT
	goto BattleFrontier_BattleFactoryPreBattleRoom_EventScript_EnterBattleRoom_hns

