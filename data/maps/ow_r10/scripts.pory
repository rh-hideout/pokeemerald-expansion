script ow_r10_EventScript_CombeeReturnedMsg {
    goto_if_eq(VAR_R10_HONEY_COMBEE, 6, ow_r10_EventScript_AllCombeeHome)
    buffernumberstring(STR_VAR_1, VAR_R10_HONEY_COMBEE)
    msgbox(format("The Combee returned to the hives.\n{STR_VAR_1} of 6 gathered so far."), MSGBOX_DEFAULT)
    release
    end
}

script ow_r10_EventScript_AllCombeeHome {
    msgbox(format("The Combee returned to the hives.\nAll six are home."), MSGBOX_DEFAULT)
    completesubquest(QUEST_HONEY, SUB_QUEST_HONEY_COMBEE)
    questmenu(QUEST_MENU_SET_REWARD, QUEST_HONEY)
    release
    end
}

// ============================================================
// HILL TM TRADE NPC (one-off honey -> TM) - LOCALID_R10_HILL_TM_NPC
// ============================================================

script ow_r10_EventScript_HillTmNpc {
    lock
    faceplayer
    setspeaker("Apiary Watcher")
    goto_if_set(FLAG_R10_HONEY_TRADED, ow_r10_EventScript_HillTmNpc_Done)
    msgbox(format("Smell that?\NMelli lets her bees forage amongst the wildflowers.\pThat's why her honey tastes different. It's the wildflowers."))
    checkitem(ITEM_HONEY, 1)
    goto_if_eq(VAR_RESULT, FALSE, ow_r10_EventScript_HillTmNpc_NoHoney)
    msgbox(format("Hold on - is that a jar from her apiary?\NWould you part with it? I've something I'd trade for it."), MSGBOX_YESNO)
    goto_if_eq(VAR_RESULT, NO, ow_r10_EventScript_HillTmNpc_Declined)
    removeitem(ITEM_HONEY, 1)
    giveitem(ITEM_TM_GIGA_DRAIN)
    setflag(FLAG_R10_HONEY_TRADED)
    msgbox(format("That's a fair trade, in my book."))
    setspeaker(NULL)
    release
    end
}

script ow_r10_EventScript_HillTmNpc_NoHoney {
    msgbox(format("If you ever get hold of a jar of hers, come find me.\NI've something I'd trade for it."))
    setspeaker(NULL)
    release
    end
}

script ow_r10_EventScript_HillTmNpc_Declined {
    msgbox(format("Fair enough. Hold onto it."))
    setspeaker(NULL)
    release
    end
}

script ow_r10_EventScript_HillTmNpc_Done {
    msgbox(format("That honey is delicious.\NThank you again."))
    setspeaker(NULL)
    release
    end
}

// ============================================================
// CAMPER (one-off item gift) - LOCALID_R10_CAMPER
// ============================================================

script ow_r10_EventScript_Camper {
    lock
    faceplayer
    setspeaker("Camper")
    goto_if_set(FLAG_R10_CAMPER_GIFT, ow_r10_EventScript_Camper_Done)
    msgbox(format("First time down this track?\pIt's quiet but the trees crowd in close.\NSome of the bug Pokémon get bold around here."))
    msgbox(format("Here - take this. It'll keep them off you for a bit."))
    giveitem(ITEM_REPEL)
    setflag(FLAG_R10_CAMPER_GIFT)
    setspeaker(NULL)
    release
    end
}

script ow_r10_EventScript_Camper_Done {
    msgbox(format("Quiet down here, isn't it?\NI'm not in a rush to head back up."))
    setspeaker(NULL)
    release
    end
}

