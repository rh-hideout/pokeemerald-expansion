    lock
    faceplayer
    playmoncry(SPECIES_CHANSEY, CRY_MODE_NORMAL)
    waitmoncry
    release
    end
}

// ============================================================
// TRAINERS
// ============================================================

script ow_r10_EventScript_Picnicker {
    trainerbattle_single(
        TRAINER_OW_R10_PICNICKER,
        ow_r10_Text_Picnicker_Intro,
        ow_r10_Text_Picnicker_Defeat
    )
    msgbox(format("There's something special down here. I can feel it.\NI just need to keep looking."), MSGBOX_AUTOCLOSE)
}

text ow_r10_Text_Picnicker_Intro {
    "I was just having a lovely picnic!\pJoin me - in a battle first!"
}

text ow_r10_Text_Picnicker_Defeat {
    "You're tough!\nWant to share my lunch?"
}

script ow_r10_EventScript_Blackbelt {
    trainerbattle_single(
        TRAINER_OW_R10_BLACKBELT,
        ow_r10_Text_Blackbelt_Intro,
        ow_r10_Text_Blackbelt_Defeat
    )
    msgbox(format("The lumberjacks asked me to move.\pPfft!\NI can split wood without their axes."), MSGBOX_AUTOCLOSE)
}

text ow_r10_Text_Blackbelt_Intro {
    "KIIAAAI!\pYou stepped into my training\lspace. Show me what you've got."
}

text ow_r10_Text_Blackbelt_Defeat {
    "Hoo-hah!\nMy stance was completely broken!"
}

script ow_r10_EventScript_LumberjackF1 {
    trainerbattle_single(
        TRAINER_OW_R10_LUMBERJACK_F1,
        ow_r10_Text_LumberjackF1_Intro,
        ow_r10_Text_LumberjackF1_Defeat
    )
    msgbox(format("Just three more trees to fell before we can take a break..."), MSGBOX_AUTOCLOSE)
}

text ow_r10_Text_LumberjackF1_Intro {
    format("We're thinning out the overgrowth on this trail!\pIf you want to clear this pass, you'll need to break\lour wooden defense lines!")
}

text ow_r10_Text_LumberjackF1_Defeat {
    "Timber!"
}

script ow_r10_EventScript_LumberjackF2 {
    trainerbattle_single(
        TRAINER_OW_R10_LUMBERJACK_F2,
        ow_r10_Text_LumberjackF2_Intro,
        ow_r10_Text_LumberjackF2_Defeat
    )
    msgbox(format("Honey or timber. People want both.\NAct like only one of us is the problem."), MSGBOX_AUTOCLOSE)
}

text ow_r10_Text_LumberjackF2_Intro {
    "You wandered into a cut site, kid.\pStep carefully - or step into a battle."
}

text ow_r10_Text_LumberjackF2_Defeat {
    "You have a strong arm.\nCould use a crew member like that."
}

script ow_r10_EventScript_LumberjackM1 {
    trainerbattle_single(
        TRAINER_OW_R10_LUMBERJACK_M1,
        ow_r10_Text_LumberjackM1_Intro,
        ow_r10_Text_LumberjackM1_Defeat
    )
    msgbox(format("These Combee keep getting in the way.\pWe need to steer clear of the Vespiquen, though."), MSGBOX_AUTOCLOSE)
}

text ow_r10_Text_LumberjackM1_Intro {
    "Help me stack these logs!\nOr fight me. Either works."
}

text ow_r10_Text_LumberjackM1_Defeat {
    "Ugh, I guess I'll do it myself..."
}

script ow_r10_EventScript_LumberjackM2 {
    trainerbattle_single(
        TRAINER_OW_R10_LUMBERJACK_M2,
        ow_r10_Text_LumberjackM2_Intro,
        ow_r10_Text_LumberjackM2_Defeat
    )
    msgbox(format("Truth is, I'd take the Combeekeeper's job over mine.\pDon't tell the crew I said that."), MSGBOX_AUTOCLOSE)
}

text ow_r10_Text_LumberjackM2_Intro {
    "Heard the hum from the apiary?\nThe bees know when we're working\lclose. They don't like it."
}

text ow_r10_Text_LumberjackM2_Defeat {
    "Fair fight.\nBack to the saw."
}

