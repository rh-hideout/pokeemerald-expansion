// ============================================================
// NURSE + CHANSEY (outdoor heal) - LOCALID_R10_NURSE, LOCALID_R10_CHANSEY
// ============================================================

script ow_r10_EventScript_Nurse {
    lock
    faceplayer
    setspeaker("Nurse")
    msgbox(format("You look like you've been at it a while.\NLet me take a look at your team."), MSGBOX_YESNO)
    goto_if_eq(VAR_RESULT, NO, ow_r10_EventScript_Nurse_Decline)
    closemessage
    call(Common_EventScript_OutOfCenterPartyHeal)
    msgbox(format("There you go. Mind how you step out there."))
    setspeaker(NULL)
    release
    end
}

script ow_r10_EventScript_Nurse_Decline {
    msgbox(format("Alright. I'll be here if you change your mind."))
    setspeaker(NULL)
    release
    end
}

