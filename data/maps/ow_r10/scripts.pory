script ow_r10_EventScript_AmbientCombee {
    lock
    faceplayer
    playmoncry(SPECIES_COMBEE, CRY_MODE_NORMAL)
    waitmoncry
    release
    end
}

script ow_r10_EventScript_Combeekeeper_Done {
    msgbox(format("The hives are settled. The honey will keep flowing.\NThank you."))
    setspeaker(NULL)
    release
    end
}

