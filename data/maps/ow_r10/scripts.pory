mapscripts ow_r10_MapScripts {}

// ============================================================
// COMBEEKEEPER (quest-giver) - LOCALID_R10_COMBEEKEEPER
// ============================================================

script ow_r10_EventScript_Combeekeeper {
    lock
    faceplayer
    setspeaker("Combeekeeper")
    goto_if_quest_complete(QUEST_HONEY, ow_r10_EventScript_Combeekeeper_Done)
    goto_if_quest_reward(QUEST_HONEY, ow_r10_EventScript_Combeekeeper_Reward)
    goto_if_quest_active(QUEST_HONEY, ow_r10_EventScript_Combeekeeper_Active)
    goto(ow_r10_EventScript_Combeekeeper_Intro)
}

script ow_r10_EventScript_Combeekeeper_Intro {
    msgbox(format("A powerful Heracross has broken into the apiary - it's tearing through the honey stores!"))
    msgbox(format("The bees scattered the moment it came crashing in.\NI tried to fend it off, but I'm not strong enough."))
    msgbox(format("Could you drive it off? My Combee won't return until it's gone."))
    setspeaker(NULL)
    startquest(QUEST_HONEY)
    subquestmenu(QUEST_MENU_UNLOCK_QUEST, QUEST_HONEY, SUB_QUEST_HONEY_HERACROSS)
    clearflag(FLAG_HIDE_R10_HERACROSS)
    release
    end
}

script ow_r10_EventScript_Combeekeeper_Active {
    goto_if_eq(VAR_R10_HONEY_COMBEE, 6, ow_r10_EventScript_Combeekeeper_AllCombeeIn)
    goto_if_subquest_complete(QUEST_HONEY, SUB_QUEST_HONEY_HERACROSS, ow_r10_EventScript_Combeekeeper_HeracrossDown)
    goto(ow_r10_EventScript_Combeekeeper_HeracrossPending)
}

script ow_r10_EventScript_Combeekeeper_HeracrossDown {
    goto_if_set(FLAG_R10_HONEY_THANKED, ow_r10_EventScript_Combeekeeper_CombeePending)
    msgbox(format("Oh, thank you. Truly.\NYou actually drove it off."))
    msgbox(format("But the hives are still empty.\pMy Combee scattered when it came crashing in - they'll be in the nearby fields. Could you help me find them?"))
    setflag(FLAG_R10_HONEY_THANKED)
    subquestmenu(QUEST_MENU_UNLOCK_QUEST, QUEST_HONEY, SUB_QUEST_HONEY_COMBEE)
    setspeaker(NULL)
    release
    end
}

script ow_r10_EventScript_Combeekeeper_HeracrossPending {
    msgbox(format("The Heracross is still rattling around the hives.\NIt's just south of here."))
    setspeaker(NULL)
    release
    end
}

script ow_r10_EventScript_Combeekeeper_CombeePending {
    buffernumberstring(STR_VAR_1, VAR_R10_HONEY_COMBEE)
    msgbox(format("You've brought {STR_VAR_1} of my Combee back so far.\pThey need someone to nudge them in the right direction to come home."))
    setspeaker(NULL)
    release
    end
}

script ow_r10_EventScript_Combeekeeper_AllCombeeIn {
    msgbox(format("All of them are home! I can hear the hive humming properly again."))
    msgbox(format("Take this - it's the least I owe you.\NIt's been in my family longer than the apiary has."))
    giveitem(ITEM_HM01)
    setspeaker(NULL)
    completequest(QUEST_HONEY)
    call(ow_r10_EventScript_RevealAmbientCombee)
    release
    end
}

script ow_r10_EventScript_Combeekeeper_Reward {
    msgbox(format("All of them are home! I can hear the hive humming properly again."))
    msgbox(format("Take this - it's the least I owe you.\NIt's been in my family longer than the apiary has."))
    giveitem(ITEM_HM01)
    setspeaker(NULL)
    completequest(QUEST_HONEY)
    call(ow_r10_EventScript_RevealAmbientCombee)
    release
    end
}

script ow_r10_EventScript_RevealAmbientCombee {
    clearflag(FLAG_HIDE_R10_AMBIENT_COMBEE)
    addobject(LOCALID_R10_VESPIQUEN)
    addobject(LOCALID_R10_AMBIENT_COMBEE_1)
    addobject(LOCALID_R10_AMBIENT_COMBEE_2)
    addobject(LOCALID_R10_AMBIENT_COMBEE_3)
    addobject(LOCALID_R10_AMBIENT_COMBEE_4)
    addobject(LOCALID_R10_AMBIENT_COMBEE_5)
    addobject(LOCALID_R10_AMBIENT_COMBEE_6)
    return
}

