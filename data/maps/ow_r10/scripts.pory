// COMBEEKEEPER (apiary) - LOCALID_R10_COMBEEKEEPER_APIARY
// ============================================================

script ow_r10_EventScript_CombeekeeperApiary {
    lock
    faceplayer
    setspeaker("Combeekeeper")
    goto_if_quest_complete(QUEST_HONEY, ow_r10_EventScript_CombeekeeperApiary_Done)
    msgbox(format("My poor bees.\NThey're scattered all over the route."))
    setspeaker(NULL)
    release
    end
}

script ow_r10_EventScript_CombeekeeperApiary_Done {
    msgbox(format("Listen to them. That hum is the sound of a hive that knows it's safe."))
    setspeaker(NULL)
    release
    end
}

// ============================================================
// HERACROSS BOSS - LOCALID_R10_HERACROSS
// ============================================================

script ow_r10_EventScript_Heracross {
    lock
    faceplayer
    playmoncry(SPECIES_HERACROSS, CRY_MODE_ENCOUNTER)
    msgbox(format("The Heracross attacks!"), MSGBOX_DEFAULT)
    waitmoncry
    closemessage
    delay(30)
    setflag(FLAG_NO_CATCHING_BOSS)
    setflag(FLAG_NUZLOCKE_SKIP_ENCOUNTER)
    setvar(VAR_0x8000, SPECIES_HERACROSS)
    special(SetupBossWildBattle)
    dowildbattle
    clearflag(FLAG_NO_CATCHING_BOSS)
    clearflag(FLAG_NUZLOCKE_SKIP_ENCOUNTER)
    specialvar(VAR_RESULT, GetBattleOutcome)
    goto_if_ne(VAR_RESULT, B_OUTCOME_WON, ow_r10_EventScript_Heracross_NotDefeated)
    fadescreen(FADE_TO_BLACK)
    setflag(FLAG_HIDE_R10_HERACROSS)
    removeobject(LOCALID_R10_HERACROSS)
    fadescreen(FADE_FROM_BLACK)
    msgbox(format("The Heracross ran away and dropped some honey!"), MSGBOX_DEFAULT)
    giveitem(ITEM_HONEY)
    completesubquest(QUEST_HONEY, SUB_QUEST_HONEY_HERACROSS)
    clearflag(FLAG_HIDE_R10_COMBEE_1)
    clearflag(FLAG_HIDE_R10_COMBEE_2)
    clearflag(FLAG_HIDE_R10_COMBEE_3)
    clearflag(FLAG_HIDE_R10_COMBEE_4)
    clearflag(FLAG_HIDE_R10_COMBEE_5)
    clearflag(FLAG_HIDE_R10_COMBEE_6)
    addobject(LOCALID_R10_COMBEE_1)
    addobject(LOCALID_R10_COMBEE_2)
    addobject(LOCALID_R10_COMBEE_3)
    addobject(LOCALID_R10_COMBEE_4)
    addobject(LOCALID_R10_COMBEE_5)
    addobject(LOCALID_R10_COMBEE_6)
    release
    end
}

script ow_r10_EventScript_Heracross_NotDefeated {
    release
    end
}

// ============================================================
// COMBEE (quest objects) - LOCALID_R10_COMBEE_1..6
// ============================================================

script ow_r10_EventScript_CombeeScared {
    lock
    faceplayer
    playmoncry(SPECIES_COMBEE, CRY_MODE_ENCOUNTER)
    msgbox(format("The Combee is scared and confused.\NIt won't budge."), MSGBOX_DEFAULT)
    waitmoncry
    release
    end
}

movement ow_r10_Movement_CombeeHeart {
    emote_heart
    delay_16
    delay_16
}

script ow_r10_EventScript_Combee1 {
    lock
    faceplayer
    goto_if_subquest_not_complete(QUEST_HONEY, SUB_QUEST_HONEY_HERACROSS, ow_r10_EventScript_CombeeScared)
    playmoncry(SPECIES_COMBEE, CRY_MODE_NORMAL)
    applymovement(LOCALID_R10_COMBEE_1, ow_r10_Movement_CombeeHeart)
    waitmovement(0)
    waitmoncry
    fadescreen(FADE_TO_BLACK)
    removeobject(LOCALID_R10_COMBEE_1)
    setflag(FLAG_HIDE_R10_COMBEE_1)
    addvar(VAR_R10_HONEY_COMBEE, 1)
    fadescreen(FADE_FROM_BLACK)
    goto(ow_r10_EventScript_CombeeReturnedMsg)
}

