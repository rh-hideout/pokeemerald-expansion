
VerdanturfTown_BattleTentCorridor_hns_MapScripts::
	map_script MAP_SCRIPT_ON_FRAME_TABLE, VerdanturfTown_BattleTentCorridor_hns_OnFrame
	.byte 0

VerdanturfTown_BattleTentCorridor_hns_OnFrame:
	map_script_2 VAR_TEMP_0, 0, VerdanturfTown_BattleTentCorridor_hns_EventScript_EnterCorridor
	.2byte 0

VerdanturfTown_BattleTentCorridor_hns_EventScript_EnterCorridor::
	lockall
	setvar VAR_TEMP_0, 1
	applymovement LOCALID_VERDANTURF_TENT_CORRIDOR_HNS_ATTENDANT, VerdanturfTown_BattleTentCorridor_hns_Movement_WalkToDoor
	applymovement LOCALID_PLAYER, VerdanturfTown_BattleTentCorridor_hns_Movement_WalkToDoor
	waitmovement 0
	opendoor 2, 1
	waitdooranim
	applymovement LOCALID_VERDANTURF_TENT_CORRIDOR_HNS_ATTENDANT, VerdanturfTown_BattleTentCorridor_hns_Movement_AttendantEnterDoor
	applymovement LOCALID_PLAYER, VerdanturfTown_BattleTentCorridor_hns_Movement_PlayerEnterDoor
	waitmovement 0
	closedoor 2, 1
	waitdooranim
	setvar VAR_0x8006, 0
	warp MAP_VERDANTURF_TOWN_BATTLE_TENT_BATTLE_ROOM_HNS, 6, 5
	waitstate
	releaseall
	end

VerdanturfTown_BattleTentCorridor_hns_Movement_WalkToDoor:
	walk_up
	walk_up
	walk_up
	walk_up
	step_end

VerdanturfTown_BattleTentCorridor_hns_Movement_PlayerEnterDoor:
	walk_up
VerdanturfTown_BattleTentCorridor_hns_Movement_AttendantEnterDoor:
	walk_up
	set_invisible
	step_end


