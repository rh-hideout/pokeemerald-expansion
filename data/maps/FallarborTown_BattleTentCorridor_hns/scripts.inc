
FallarborTown_BattleTentCorridor_hns_MapScripts::
	map_script MAP_SCRIPT_ON_FRAME_TABLE, FallarborTown_BattleTentCorridor_hns_OnFrame
	.byte 0

FallarborTown_BattleTentCorridor_hns_OnFrame:
	map_script_2 VAR_TEMP_0, 0, FallarborTown_BattleTentCorridor_hns_EventScript_EnterCorridor
	.2byte 0

FallarborTown_BattleTentCorridor_hns_EventScript_EnterCorridor::
	lockall
	setvar VAR_TEMP_0, 1
	applymovement LOCALID_FALLARBOR_TENT_CORRIDOR_HNS_ATTENDANT, FallarborTown_BattleTentCorridor_hns_Movement_WalkToDoor
	applymovement LOCALID_PLAYER, FallarborTown_BattleTentCorridor_hns_Movement_WalkToDoor
	waitmovement 0
	opendoor 2, 1
	waitdooranim
	applymovement LOCALID_FALLARBOR_TENT_CORRIDOR_HNS_ATTENDANT, FallarborTown_BattleTentCorridor_hns_Movement_AttendantEnterDoor
	applymovement LOCALID_PLAYER, FallarborTown_BattleTentCorridor_hns_Movement_PlayerEnterDoor
	waitmovement 0
	closedoor 2, 1
	waitdooranim
	setvar VAR_0x8006, 0
	warp MAP_FALLARBOR_TOWN_BATTLE_TENT_BATTLE_ROOM_HNS, 4, 4
	waitstate
	releaseall
	end

FallarborTown_BattleTentCorridor_hns_Movement_WalkToDoor:
	walk_up
	walk_up
	walk_up
	walk_up
	step_end

FallarborTown_BattleTentCorridor_hns_Movement_PlayerEnterDoor:
	walk_up
FallarborTown_BattleTentCorridor_hns_Movement_AttendantEnterDoor:
	walk_up
	set_invisible
	step_end

